# === Keystone Authentication ===
OS_AUTH_URL=https://keystone.example.com/v3
OS_IDENTITY_API_VERSION=3
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default
# OS_REGION_NAME=RegionOne
# OS_TENANT_ID=
# OS_TENANT_NAME=

# === Barbican Endpoint ===
# If BARBICAN_ENDPOINT_AUTODISCOVERY=true (default), the app discovers the
# Barbican endpoint from the Keystone service catalog.
# OS_BARBICAN_ENDPOINT always overrides autodiscovery when set.
# If BARBICAN_ENDPOINT_AUTODISCOVERY=false, OS_BARBICAN_ENDPOINT is mandatory.
BARBICAN_ENDPOINT_AUTODISCOVERY=true
# OS_BARBICAN_ENDPOINT=https://key-manager.example.com/v1

# === Application ===
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
SESSION_LIFETIME_SECONDS=3600
CACHE_TTL_SECONDS=300
CACHE_DIR=/tmp/barbican-ui-cache
LOG_LEVEL=INFO
FLASK_PORT=8080

